# Neon Database Connection
DATABASE_URL="postgresql://your-neon-database-url"
DIRECT_URL="postgresql://your-neon-direct-url"

# Groq API for AI services
GROQ_API_KEY=your-groq-api-key
NEXT_PUBLIC_GROQ_API_KEY=your-groq-api-key
OPENAI_API_KEY=your-openai-api-key-placeholder

# Cloudflare R2 Mock / Integration
CLOUDFLARE_R2_ACCESS_KEY=your-r2-access-key
CLOUDFLARE_R2_SECRET_KEY=your-r2-secret-key
CLOUDFLARE_R2_BUCKET=your-r2-bucket
CLOUDFLARE_R2_ENDPOINT=your-r2-endpoint

# Integrations
YOUTUBE_API_KEY=your-youtube-api-key
ELEVENLABS_API_KEY=your-elevenlabs-api-key
SEMANTIC_SCHOLAR_API_KEY=your-semantic-scholar-api-key

# Auth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
NEXTAUTH_SECRET=your-nextauth-secret-placeholder
NEXTAUTH_URL=http://localhost:3000

# SMTP Configuration (For password reset emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
